@using APP.Application.Security
@{
    ViewData["Title"] = "Reports";
}

<section class="page-heading">
    <div>
        <h1>Reports</h1>
        <p class="text-muted">Report actions and widgets render only when the signed-in user has access.</p>
    </div>
</section>

<div class="row g-3">
    <div class="col-md-4">
        <div class="metric-card">
            <span>Total Sales</span>
            <strong>$42,700</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card">
            <span>Open Orders</span>
            <strong>18</strong>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card">
            <span>Pending Reviews</span>
            <strong>7</strong>
        </div>
    </div>
</div>

@if (User.HasPermission(AppPermissions.UsersManage))
{
    <div class="mt-4">
        <button type="button" class="btn btn-outline-primary" data-modal-url="@Url.Action("UserEditor", "Admin")" data-modal-title="Create user">
            Open admin popup
        </button>
    </div>
}
