@using APP.Application.Identity
@using APP.Application.Security
@inject IMenuService MenuService
@{
    var isSignedIn = User.Identity?.IsAuthenticated == true;
    var menuItems = isSignedIn
        ? await MenuService.GetMenuAsync(User, (controller, action) => Url.Action(action, controller) ?? "#")
        : Array.Empty<MenuItemDto>();
    var displayName = User.FindFirst(AppClaimTypes.DisplayName)?.Value ?? User.Identity?.Name;
    var avatarInitial = (displayName ?? "U").Substring(0, 1).ToUpperInvariant();
}
