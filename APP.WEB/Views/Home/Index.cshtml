@{
    ViewData["Title"] = "Dashboard";
}

<div class="ab-page">
    <div class="ab-page-header">
        <div>
            <h1>Dashboard</h1>
            <p>Cookie auth, permission checks, and AJAX page loading are active.</p>
        </div>
    </div>

    <div class="ds-grid ds-col-3">
        <div class="ds-metric">
            <span class="ds-metric-label">Signed in as</span>
            <span class="ds-metric-value" style="font-size:1.375rem;">@User.Identity?.Name</span>
        </div>
        <div class="ds-metric">
            <span class="ds-metric-label">Authentication</span>
            <span class="ds-metric-value" style="font-size:1.375rem;">Cookie</span>
        </div>
        <div class="ds-metric">
            <span class="ds-metric-label">Navigation</span>
            <span class="ds-metric-value" style="font-size:1.375rem;">AJAX</span>
        </div>
    </div>
</div>
