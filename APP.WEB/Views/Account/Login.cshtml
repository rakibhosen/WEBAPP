@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<style>
/* =========================
   BACKGROUND (Sky + Wave)
========================= */
.login-wrapper {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;

    background: linear-gradient(-45deg, #dbeafe, #e0f2fe, #f0f9ff, #bae6fd);
    background-size: 400% 400%;
    animation: skyMove 12s ease infinite;

    position: relative;
    overflow: hidden;
}

/* Waves */
.login-wrapper::after {
    content: "";
    position: absolute;
    bottom: -80px;
    left: 0;
    width: 200%;
    height: 200px;
    background: rgba(14, 165, 233, 0.15);
    border-radius: 50%;
    animation: waveMove 8s ease-in-out infinite;
}

.login-wrapper::before {
    content: "";
    position: absolute;
    bottom: -100px;
    left: -50%;
    width: 200%;
    height: 220px;
    background: rgba(59, 130, 246, 0.12);
    border-radius: 50%;
    animation: waveMove2 10s ease-in-out infinite;
}

/* =========================
   CARD (Google Style)
========================= */
.login-card {
    width: 360px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    padding: 28px;
    border-radius: 18px;
    box-shadow: 0 12px 35px rgba(0,0,0,0.08);
    z-index: 2;
}

/* =========================
   BRAND
========================= */
.brand-section {
    text-align: center;
    margin-bottom: 18px;
}

.logo {
    width: 46px;
    height: 46px;
    margin: 0 auto 10px;
    background: linear-gradient(135deg, #3b82f6, #0ea5e9);
    color: white;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
}

.brand-section h2 {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
}

.brand-section p {
    margin: 0;
    font-size: 12px;
    color: #6b7280;
}

/* =========================
   INPUTS (FIXED - MODERN)
========================= */
.input-group {
    margin-bottom: 14px;
}

.input-group label {
    font-size: 12px;
    margin-bottom: 6px;
    display: block;
    color: #475569;
    font-weight: 500;
}

.custom-input {
    width: 100%;
    height: 38px;
    font-size: 13px;

    border-radius: 12px;
    border: 1px solid rgba(148, 163, 184, 0.4);

    background: rgba(255, 255, 255, 0.8);
    padding: 8px 12px;

    transition: all 0.25s ease;

    box-shadow: inset 0 1px 2px rgba(0,0,0,0.02);
}

/* Hover */
.custom-input:hover {
    border-color: rgba(59, 130, 246, 0.4);
}

/* Focus (important premium effect) */
.custom-input:focus {
    border-color: #3b82f6;
    box-shadow:
        0 0 0 4px rgba(59,130,246,0.15),
        0 6px 18px rgba(59,130,246,0.08);

    background: #fff;
    outline: none;
}

/* =========================
   BUTTON
========================= */
.btn-primary {
    width: 100%;
    background: linear-gradient(135deg, #3b82f6, #0ea5e9);
    border: none;
    border-radius: 12px;
    font-size: 13px;
    padding: 9px;
    transition: 0.2s;
}

.btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 20px rgba(59,130,246,0.25);
}

/* =========================
   FOOTER
========================= */
.footer-note {
    margin-top: 12px;
    text-align: center;
    font-size: 11px;
    color: #6b7280;
}

/* =========================
   ANIMATIONS
========================= */
@@keyframes skyMove {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

@@keyframes waveMove {
    0% { transform: translateX(0) translateY(0); }
    50% { transform: translateX(-10%) translateY(10px); }
    100% { transform: translateX(0) translateY(0); }
}

@@keyframes waveMove2 {
    0% { transform: translateX(0); }
    50% { transform: translateX(10%) translateY(5px); }
    100% { transform: translateX(0); }
}
</style>

<div class="login-wrapper">
    <div class="login-card">

        <!-- Brand -->
        <div class="brand-section">
            <div class="logo">DM</div>
            <h2>Demo</h2>
            <p>Administrative Portal</p>
        </div>

        <!-- Form -->
        <form asp-action="Login" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()

            <input asp-for="ReturnUrl" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

            <!-- Username -->
            <div class="input-group">
                <label asp-for="UserName"></label>
                <input asp-for="UserName" class="custom-input" autocomplete="username" />
                <span asp-validation-for="UserName" class="text-danger small"></span>
            </div>

            <!-- Password -->
            <div class="input-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" class="custom-input" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <!-- Button -->
            <button type="submit" class="btn btn-primary">
                Sign In
            </button>

            <div class="footer-note">
                Secure access only for authorized users
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}