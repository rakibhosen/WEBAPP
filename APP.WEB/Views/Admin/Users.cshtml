@model UserAccessViewModel
@{
    ViewData["Title"] = "User Access";
}

<div class="ab-page">
    <div class="ab-page-header">
        <div>
            <h1>User Access</h1>
            <p>Manage operator roles, branch privileges, and permission coverage.</p>
        </div>
        <button type="button" class="ds-btn ds-btn-primary"
                data-modal-url="@Url.Action("UserEditor", "Admin")"
                data-modal-title="Create user">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14" /></svg>
            New user
        </button>
    </div>

    <!-- Summary metrics -->
    <div class="ds-grid ds-col-3" style="margin-bottom:28px;">
        <div class="ds-metric">
            <span class="ds-metric-label">Active Operators</span>
            <span class="ds-metric-value">@Model.ActiveOperatorCount</span>
        </div>
        <div class="ds-metric">
            <span class="ds-metric-label">Privileged Roles</span>
            <span class="ds-metric-value">@Model.PrivilegedRoleCount</span>
        </div>
        <div class="ds-metric">
            <span class="ds-metric-label">Access Policy</span>
            <span class="ds-metric-value" style="font-size:1.25rem;">@Model.AccessPolicy</span>
        </div>
    </div>

    <!-- Users table -->
    <div class="ds-table-wrap">
        <table class="ds-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Role</th>
                    <th>Permissions</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    var initial = string.IsNullOrWhiteSpace(user.DisplayName) ? "U" : user.DisplayName[..1].ToUpperInvariant();
                    var roleText = user.Roles.Count > 0 ? string.Join(", ", user.Roles) : "Unassigned";
                    var permText = user.Permissions.Count > 0 ? string.Join(", ", user.Permissions) : "No permissions";
                    var roleClass = user.Roles.Contains("Admin", StringComparer.OrdinalIgnoreCase) ? "ds-role-admin"
                                    : user.Roles.Contains("Manager", StringComparer.OrdinalIgnoreCase) ? "ds-role-manager"
                                    : "ds-role-user";
                    <tr>
                        <td>
                            <div class="ds-user-cell">
                                <span class="ds-avatar ds-avatar-md">@initial</span>
                                <span>
                                    <strong>@user.DisplayName</strong>
                                    <small>@user.UserName</small>
                                </span>
                            </div>
                        </td>
                        <td><span class="ds-role-pill @roleClass">@roleText</span></td>
                        <td><span class="ds-text-muted ds-text-sm">@permText</span></td>
                        <td class="text-end">
                            <button type="button"
                                    class="ds-btn ds-btn-ghost ds-btn-sm"
                                    data-modal-url="@Url.Action("UserEditor", "Admin")"
                                    data-modal-title="Edit @user.DisplayName">
                                Edit
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
