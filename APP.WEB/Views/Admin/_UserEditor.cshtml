@model IReadOnlyCollection<APP.Domain.Identity.AppRole>

<form>
    <div class="form-section-title">Operator profile</div>
    <div class="mb-3">
        <label class="form-label" for="displayName">Display name</label>
        <input id="displayName" class="form-control" placeholder="Example User" />
    </div>
    <div class="mb-3">
        <label class="form-label" for="role">Role</label>
        <select id="role" class="form-select">
            @foreach (var role in Model)
            {
                <option>@role.Name</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label" for="branch">Branch / unit</label>
        <input id="branch" class="form-control" placeholder="Head Office Operations" />
    </div>
    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Save</button>
    </div>
</form>
