@model IReadOnlyCollection<APP.Domain.Identity.AppRole>

<form>
    <div class="ab-editor-section-title">Operator profile</div>

    <div class="ds-form-group" style="margin-bottom:16px;">
        <label class="ds-label" for="displayName">Display name</label>
        <input id="displayName" class="ds-input" type="text" placeholder="Example User" />
        <div class="ds-form-hint">Visible in logs, reports, and the topbar.</div>
    </div>

    <div class="ds-form-group" style="margin-bottom:16px;">
        <label class="ds-label" for="role">Role</label>
        <select id="role" class="ds-select">
            @foreach (var role in Model)
            {
                <option>@role.Name</option>
            }
        </select>
    </div>

    <div class="ds-form-group" style="margin-bottom:24px;">
        <label class="ds-label" for="branch">Branch / unit</label>
        <input id="branch" class="ds-input" type="text" placeholder="Head Office Operations" />
    </div>

    <div class="d-flex justify-content-end gap-2">
        <button type="button" class="ds-btn ds-btn-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="ds-btn ds-btn-primary" data-bs-dismiss="modal">Save operator</button>
    </div>
</form>
